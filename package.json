{
	"name": "@lemons_dev/parsinom",
	"version": "0.1.1",
	"description": "",
	"main": "ParsiNOM.js",
	"type": "module",
	"scripts": {
		"clean": "rm -rf lib",
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"test:adv": "bun test -t=advanced",
		"snapshots": "bun test --update-snapshots",
		"perf": "bun run profiling/Profiling.ts",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint --max-warnings=0 src/**",
		"lint:fix": "eslint --max-warnings=0 --fix src/**",
		"check": "bun run format:check && bun run lint && bun run typecheck && bun run test",
		"check:fix": "bun run format && bun run lint:fix && bun run typecheck && bun run test"
	},
	"keywords": [],
	"author": "Moritz Jung",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/mProjectsCode/parsiNOM.git"
	},
	"devDependencies": {
		"@types/bun": "^1.3.13",
		"eslint": "^9.39.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-only-warn": "^1.2.1",
		"mitata": "^1.0.34",
		"prettier": "^3.8.3",
		"tsdown": "^0.21.10",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.0"
	},
	"files": [
		"lib/**/*"
	],
	"exports": {
		".": {
			"import": "./lib/index.mjs",
			"types": "./lib/index.d.mts"
		}
	},
	"dependencies": {}
}
